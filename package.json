{
  "name": "phonix",
  "version": "0.1.0",
  "private": true,
  "description": "Build edge dApps once. Run them confidentially on millions of smartphones.",
  "workspaces": [
    "packages/*",
    "templates/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build --filter=./packages/*",
    "dev": "turbo run dev",
    "test": "turbo run test --filter=./packages/*",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^1.13.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": "20.x"
  }
}

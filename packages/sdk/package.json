{
  "name": "@phonix/sdk",
  "version": "0.2.0",
  "description": "Provider-abstracted SDK for deploying and calling confidential edge applications across DePIN compute networks (Acurast, Akash, Fluence, Koii).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./runtime/global": {
      "types": "./dist/runtime/global.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "depin",
    "edge",
    "tee",
    "acurast",
    "akash",
    "fluence",
    "koii",
    "decentralised-compute",
    "web3",
    "sdk",
    "routing",
    "confidential-computing"
  ],
  "author": "Phonix <hello@phonix.dev>",
  "license": "Apache-2.0",
  "homepage": "https://phonix.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/deyzho/phonix.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/deyzho/phonix/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@acurast/dapp": "1.0.1",
    "esbuild": "^0.20.0"
  },
  "optionalDependencies": {
    "@fluencelabs/js-client": "^0.15.0",
    "@fluencelabs/cli": "^0.15.0",
    "@_koii/web3.js": "^1.0.0",
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "@types/node": "^20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
